{
  "name": "10-web-time-display",
  "private": false,
  "version": "2.1.0",
  "description": "Glassmorphic neon digital clock with React 19, Vite 6, Tailwind CSS v4, and native Date API. Features clock, stopwatch, and timer modes with full accessibility support.",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:watch": "vitest"
  },
  "keywords": [
    "clock",
    "digital",
    "react",
    "typescript",
    "glassmorphism",
    "neon"
  ],
  "author": "Kazi Musharraf",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mk-knight23/10-web-time-display.git"
  },
  "homepage": "https://mk-knight23.github.io/10-web-time-display/",
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.29.2",
    "lucide-react": "^0.474.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^2.1.9",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.1.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "vite": "^6.4.1",
    "vitest": "^2.1.9",
    "@vitest/coverage-v8": "^1.3.0",
    "prettier": "^3.2.0"
  }
}
